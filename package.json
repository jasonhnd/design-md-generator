{
  "name": "design-md-gen",
  "version": "0.0.3",
  "description": "Extract design systems from any website. AI-readable DESIGN.md with pixel-verified accuracy.",
  "keywords": ["design-system", "design-md", "design-tokens", "stitch", "ai-agent", "css-extraction", "playwright"],
  "author": "Jason <jason@example.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jasonhnd/design-md-generator"
  },
  "bin": {
    "design-md-gen": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "resources/",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "extract": "ts-node scripts/extract.ts",
    "validate": "ts-node scripts/validate.ts",
    "preview": "ts-node scripts/preview-gen.ts",
    "report": "ts-node scripts/report-gen.ts",
    "proof": "ts-node scripts/proof.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "playwright": "^1.50.0",
    "playwright-extra": "^4.3.0",
    "puppeteer-extra-plugin-stealth": "^2.11.0",
    "css-tree": "^3.0.0",
    "culori": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "ts-node": "^10.9.0",
    "@types/node": "^20.0.0",
    "vitest": "^3.0.0"
  }
}
